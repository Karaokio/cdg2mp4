# Copy to .env for local runs (gitignored). All VITE_* values are PUBLIC: they are
# baked into the client bundle by design, so these are config, not secrets.
#
# In CI/production these come from GitHub repo Variables (Settings > Secrets and
# variables > Actions > Variables), read by the deploy job in .github/workflows/ci.yml.
# Leaving any of them unset simply turns that feature off (the app still builds/runs).

# PostHog product analytics (publishable project key, US cloud)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Tally feedback form (the hosted form URL, e.g. https://tally.so/r/xxxx)
VITE_TALLY_FORM_URL=
